# ── VVLeng Environment Variables ────────────────────────────────────
# Secrets-only template. All non-sensitive configuration lives in
# config.yaml and clients/*.yaml.
#
# Usage:
#   1. Copy to .env
#   2. Fill in your real secrets
#   3. NEVER commit .env
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Apify
APIFY_API_TOKEN=""

# LLM (laozhang.ai OpenAI-compatible)
LLM_API_KEY=""
LLM_BASE_URL="https://api.laozhang.ai/v1"

# Database (optional — defaults to SQLite at data/engagement.db)
# DATABASE_URL="postgresql://user:pass@host:5432/vvleng"

# Pipeline
# LOG_LEVEL="INFO"          # DEBUG | INFO | WARNING | ERROR
# PIPELINE_TIMEZONE="UTC"   # for plan timestamps